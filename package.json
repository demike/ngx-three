{
  "name": "ngx-three-workspace",
  "version": "0.43.3",
  "workspaces": [
    "projects/ngx-three",
    "projects/ngx-three-demo"
  ],
  "packageManager": "npm@11.12.1",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build ngx-three",
    "build:prod": "ng build ngx-three --configuration production",
    "build:demo": "ng build ngx-three-demo --configuration production --base-href /ngx-three/",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test-headless": "vitest run --browser.enabled",
    "lint": "ng lint",
    "e2e": "ng e2e",
    "copy:docs": "(cp README.md dist/ngx-three/ || copy README.md dist\\ngx-three)",
    "package": "ng build --configuration production ngx-three && npm run copy:docs",
    "format": "prettier-eslint --write \"{,!(node_modules|dist)/**/}*.{ts,tsx}\"",
    "test:browser": "vitest --browser.enabled",
    "test:browser:ui": "vitest --browser.enabled --ui"
  },
  "private": true,
  "dependencies": {
    "@angular/animations": "^22.0.0",
    "@angular/cdk": "^22.0.0",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/material": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/platform-browser-dynamic": "^22.0.0",
    "@angular/router": "^22.0.0",
    "@stackblitz/sdk": "^1.11.0",
    "@types/webxr": "^0.5.22",
    "highlight.js": "^11.9.0",
    "lil-gui": "^0.20.0",
    "ngx-highlightjs": "^14.0.1",
    "normalize.css": "^8.0.1",
    "rxjs": "~7.8.1",
    "simplex-noise": "^4.0.3",
    "three": "~0.182.0",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^22.0.0",
    "@angular-eslint/builder": "22.0.0",
    "@angular-eslint/eslint-plugin": "22.0.0",
    "@angular-eslint/eslint-plugin-template": "22.0.0",
    "@angular-eslint/schematics": "22.0.0",
    "@angular-eslint/template-parser": "22.0.0",
    "@angular/cli": "^22.0.0",
    "@angular/compiler-cli": "^22.0.0",
    "@types/jasmine": "^4.3.5",
    "@types/node": "^24.0.13",
    "@types/three": "^0.182.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "@vitest/browser": "^4.1.9",
    "@vitest/browser-playwright": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "acorn": ">=8",
    "angular-eslint": "^22.0.0",
    "eslint": "^9.30.1",
    "eslint-plugin-import": "^2.28.1",
    "eslint-plugin-jsdoc": "^46.5.0",
    "eslint-plugin-prefer-arrow": "^1.2.3",
    "happy-dom": "^20.10.6",
    "istanbul-lib-instrument": "^6.0.3",
    "jasmine-core": "^5.1.0",
    "jasmine-spec-reporter": "^7.0.0",
    "jsdom": "^29.1.1",
    "karma": "^6.4.2",
    "karma-chrome-launcher": "^3.2.0",
    "karma-coverage": "^2.2.1",
    "karma-jasmine": "^5.1.0",
    "karma-jasmine-html-reporter": "^2.1.0",
    "ng-packagr": "^22.0.0",
    "playwright": "^1.61.1",
    "prettier": "^3.6.2",
    "prettier-eslint": "^16.4.2",
    "prettier-eslint-cli": "^8.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "utility-types": "^3.11.0",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@angular/common": "$@angular/common",
    "@angular/core": "$@angular/core",
    "three": "$three",
    "tslib": "$tslib",
    "typescript": "$typescript",
    "ts-node": "$ts-node",
    "prettier": "$prettier",
    "utility-types": "$utility-types"
  }
}
